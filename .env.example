# Devin API credentials (required)
DEVIN_API_KEY=cog_your_api_key_here
DEVIN_ORG_ID=org-your_org_id_here

# GitHub webhook secret (required - set same value in GitHub webhook config)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub personal access token (for auto-closing issues when PRs are merged)
# Create at https://github.com/settings/tokens?type=beta with Issues: Read & Write
GITHUB_TOKEN=ghp_your_token_here

# Target repository for Devin sessions (optional, defaults to danagajewski/superset)
TARGET_REPO=danagajewski/superset

# Polling interval for session status updates in seconds (optional, defaults to 30)
POLL_INTERVAL_SECONDS=30

# ngrok auth token (required for tunnel profile - get from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
