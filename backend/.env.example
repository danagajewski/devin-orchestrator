# Devin API credentials
DEVIN_API_KEY=cog_your_api_key_here
DEVIN_ORG_ID=org-your_org_id_here

# GitHub webhook secret (set same value in GitHub webhook config)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub personal access token (for closing issues when PRs are merged)
# Create at https://github.com/settings/tokens?type=beta with Issues: Read & Write
GITHUB_TOKEN=ghp_your_token_here

# Target repository for Devin sessions
TARGET_REPO=danagajewski/superset

# Polling interval for session status updates (seconds)
POLL_INTERVAL_SECONDS=30

# Path to JSON data file
DATA_FILE_PATH=data.json
